{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "types": [],
    "baseUrl": ".",
    "paths": {
      "@nhic/currantui/*": ["./src/*"]
    }
  },
  "include": ["src", "tsup.config.ts", "eslint.config.ts"],
  "exclude": ["node_modules", "dist"]
}
