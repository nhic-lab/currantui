{
  "name": "@nhic/currantui",
  "version": "0.7.0",
  "description": "CurrantUI — the National Health Intelligence Center (NHIC) React design system: shadcn/ui + Radix primitives with Tailwind v4 tokens.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "National Health Intelligence Center (NHIC)",
  "homepage": "https://github.com/nhic-lab/currantui#readme",
  "bugs": "https://github.com/nhic-lab/currantui/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nhic-lab/currantui.git",
    "directory": "packages/currantui"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    "./globals.css": "./dist/globals.css",
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "import": "./dist/lib/*.js"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js"
    },
    "./hooks/*": {
      "types": "./dist/hooks/*.d.ts",
      "import": "./dist/hooks/*.js"
    },
    "./assets/*": "./dist/assets/*"
  },
  "scripts": {
    "build": "tsup && cp src/styles/globals.css dist/globals.css && mkdir -p dist/assets && cp src/assets/* dist/assets/",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "dependencies": {
    "@fontsource-variable/source-sans-3": "^5.2.9",
    "@internationalized/date": "^3.12.2",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-virtual": "^3.14.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "radix-ui": "^1.4.3",
    "react-aria-components": "^1.19.0",
    "shadcn": "^4.6.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@storybook/react-vite": "^9.1.20",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "^10.5.3",
    "tailwindcss": "^4.1.18",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
