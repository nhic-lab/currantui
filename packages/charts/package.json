{
  "name": "@nhic/currantui-charts",
  "version": "1.1.0",
  "description": "CurrantUI Charts — data visualization components for the National Health Intelligence Center (NHIC) design system, built on Apache ECharts.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "National Health Intelligence Center (NHIC)",
  "homepage": "https://github.com/nhic-lab/currantui#readme",
  "bugs": "https://github.com/nhic-lab/currantui/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nhic-lab/currantui.git",
    "directory": "packages/charts"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "import": "./dist/lib/*.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@nhic/currantui": ">=0.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "echarts": "^6.1.0"
  },
  "devDependencies": {
    "@nhic/currantui": "workspace:*",
    "@storybook/react-vite": "^9.1.20",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "^9.1.20",
    "tailwindcss": "^4.1.18",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
