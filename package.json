{
  "name": "@nhic/currantui",
  "version": "0.1.0",
  "description": "CurrantUI — NHIC's React design system: shadcn/ui + Radix primitives with Tailwind v4 tokens.",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nhic-lab/currantui.git"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    "./globals.css": "./dist/globals.css",
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "import": "./dist/lib/*.js"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js"
    },
    "./hooks/*": {
      "types": "./dist/hooks/*.d.ts",
      "import": "./dist/hooks/*.js"
    }
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "build": "tsup && cp src/styles/globals.css dist/globals.css",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "changeset": "changeset",
    "release": "pnpm build && changeset publish"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@9.15.9",
  "pnpm": {
    "overrides": {
      "esbuild@<0.28.1": ">=0.28.1"
    }
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/source-sans-3": "^5.2.9",
    "@phosphor-icons/react": "^2.1.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "radix-ui": "^1.4.3",
    "shadcn": "^4.6.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.5",
    "@tanstack/eslint-config": "^0.4.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "jiti": "^2.7.0",
    "prettier": "^3.6.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.1.18",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
